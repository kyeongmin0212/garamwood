---
layout: false
---
<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ settings.company.name_ko }} {{ settings.company.name_en }} — 손으로 짓는 공간</title>
<meta name="description" content="싱크대, 붙박이장, 신발장 맞춤 제작. {{ settings.company.name_ko }}는 나무의 결을 살려 공간을 완성합니다.">
<meta property="og:title" content="{{ settings.company.name_ko }} — 손으로 짓는 공간">
<meta property="og:description" content="싱크대, 붙박이장, 신발장 맞춤 제작">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400&family=Gowun+Batang:wght@400;700&family=Gowun+Dodum&display=swap" rel="stylesheet">

<style>
:root{
  --paper:#F6EFE2;--cream:#EFE5D2;--bone:#FAF6EC;
  --walnut:#2B1D11;--wood:#5C3A1E;--tan:#A57C4E;
  --sand:#C9A877;--moss:#5A6B4A;--rust:#A8542C;
  --ink:#1A1208;--line:rgba(43,29,17,0.18);
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:var(--paper);color:var(--walnut);font-family:"Gowun Dodum","Noto Sans KR",system-ui,sans-serif;font-size:16px;line-height:1.7;overflow-x:hidden;-webkit-font-smoothing:antialiased}
body::before{content:"";position:fixed;inset:0;pointer-events:none;background-image:radial-gradient(circle at 20% 30%, rgba(92,58,30,0.04) 0%, transparent 50%),radial-gradient(circle at 80% 70%, rgba(168,84,44,0.03) 0%, transparent 50%);z-index:1}
.serif{font-family:"Gowun Batang","Noto Serif KR",serif}
.fraunces{font-family:"Fraunces",serif;font-optical-sizing:auto}

nav{position:fixed;top:0;left:0;right:0;z-index:100;padding:22px 48px;display:flex;align-items:center;justify-content:space-between;backdrop-filter:blur(12px);background:rgba(246,239,226,0.75);border-bottom:1px solid transparent;transition:all .3s ease}
nav.scrolled{border-bottom-color:var(--line)}
.logo{font-family:"Fraunces",serif;font-weight:500;font-size:22px;letter-spacing:0.02em;color:var(--walnut);text-decoration:none;display:flex;align-items:center;gap:10px}
.logo-mark{width:28px;height:28px;display:inline-block}
.nav-links{display:flex;gap:36px;list-style:none;align-items:center}
.nav-links a{color:var(--walnut);text-decoration:none;font-size:14px;letter-spacing:0.05em;position:relative;padding:4px 0;transition:color .2s}
.nav-links a::after{content:"";position:absolute;bottom:0;left:0;right:0;height:1px;background:var(--wood);transform:scaleX(0);transform-origin:right;transition:transform .3s ease}
.nav-links a:hover::after{transform:scaleX(1);transform-origin:left}
.nav-cta{padding:10px 22px;border:1px solid var(--walnut);border-radius:999px;background:transparent;color:var(--walnut);font-size:13px;letter-spacing:0.05em;cursor:pointer;text-decoration:none;transition:all .3s ease}
.nav-cta:hover{background:var(--walnut);color:var(--paper)}
.menu-btn{display:none;background:none;border:none;cursor:pointer;font-size:24px;color:var(--walnut)}

.hero{min-height:100vh;padding:140px 48px 80px;position:relative;display:grid;grid-template-columns:1.2fr 1fr;gap:64px;align-items:center;overflow:hidden}
.hero-bg{position:absolute;inset:0;z-index:0;background:radial-gradient(ellipse at top right, rgba(201,168,119,0.25) 0%, transparent 60%),radial-gradient(ellipse at bottom left, rgba(92,58,30,0.08) 0%, transparent 50%)}
.hero-content{position:relative;z-index:2}
.eyebrow{display:inline-flex;align-items:center;gap:12px;font-family:"Fraunces",serif;font-style:italic;font-size:14px;color:var(--wood);margin-bottom:32px;letter-spacing:0.05em}
.eyebrow::before{content:"";width:32px;height:1px;background:var(--wood)}
h1.hero-title{font-family:"Gowun Batang",serif;font-size:clamp(40px,6vw,84px);font-weight:400;line-height:1.15;letter-spacing:-0.02em;color:var(--ink);margin-bottom:32px}
.hero-title em{font-family:"Fraunces",serif;font-style:italic;font-weight:400;color:var(--wood)}
.hero-sub{font-size:18px;line-height:1.8;color:var(--walnut);opacity:.85;max-width:520px;margin-bottom:48px}
.hero-actions{display:flex;gap:16px;align-items:center;flex-wrap:wrap}
.btn-primary{padding:16px 32px;background:var(--walnut);color:var(--paper);border:none;border-radius:999px;font-family:inherit;font-size:15px;cursor:pointer;text-decoration:none;display:inline-flex;align-items:center;gap:10px;transition:all .3s ease;letter-spacing:0.03em}
.btn-primary:hover{background:var(--wood);transform:translateY(-2px);box-shadow:0 12px 24px rgba(43,29,17,0.2)}
.btn-secondary{padding:16px 32px;background:transparent;color:var(--walnut);border:1px solid var(--walnut);border-radius:999px;font-family:inherit;font-size:15px;cursor:pointer;text-decoration:none;display:inline-flex;align-items:center;gap:10px;transition:all .3s ease}
.btn-secondary:hover{background:var(--walnut);color:var(--paper)}
.hero-visual{position:relative;z-index:1;height:560px}
.hero-img{position:absolute;border-radius:8px;overflow:hidden;box-shadow:0 30px 80px rgba(43,29,17,0.25);background-size:cover;background-position:center;background-color:var(--cream)}
.hero-img-1{top:0;right:0;width:78%;height:72%}
.hero-img-2{bottom:0;left:0;width:55%;height:45%;border:8px solid var(--paper)}
.hero-stamp{position:absolute;bottom:32px;right:32px;width:130px;height:130px;border-radius:50%;background:var(--walnut);color:var(--paper);display:flex;align-items:center;justify-content:center;font-family:"Fraunces",serif;font-style:italic;text-align:center;font-size:13px;line-height:1.4;z-index:3;animation:slow-spin 30s linear infinite}
@keyframes slow-spin{from{transform:rotate(0)}to{transform:rotate(360deg)}}

.marquee{padding:24px 0;border-top:1px solid var(--line);border-bottom:1px solid var(--line);overflow:hidden;background:var(--cream);position:relative;z-index:2}
.marquee-track{display:flex;gap:48px;animation:scroll 30s linear infinite;white-space:nowrap}
.marquee-track span{font-family:"Fraunces",serif;font-size:22px;font-style:italic;color:var(--wood);display:inline-flex;align-items:center;gap:48px}
.marquee-track span::after{content:"✦";font-style:normal;color:var(--tan)}
@keyframes scroll{from{transform:translateX(0)}to{transform:translateX(-50%)}}

.services{padding:140px 48px;position:relative;z-index:2}
.section-head{max-width:760px;margin:0 auto 80px;text-align:center}
.section-label{font-family:"Fraunces",serif;font-style:italic;font-size:14px;color:var(--rust);letter-spacing:0.1em;text-transform:uppercase;margin-bottom:20px}
.section-title{font-family:"Gowun Batang",serif;font-size:clamp(32px,4.5vw,56px);font-weight:400;line-height:1.2;letter-spacing:-0.02em;margin-bottom:20px}
.section-desc{font-size:17px;line-height:1.8;color:var(--walnut);opacity:.8;max-width:560px;margin:0 auto}
.service-grid{max-width:1280px;margin:0 auto;display:grid;grid-template-columns:repeat(3,1fr);gap:32px}
.service-card{background:var(--bone);border-radius:4px;overflow:hidden;transition:all .5s cubic-bezier(.2,.7,.2,1);cursor:pointer;border:1px solid var(--line)}
.service-card:hover{transform:translateY(-8px);box-shadow:0 30px 60px rgba(43,29,17,0.15)}
.service-img{height:320px;overflow:hidden;position:relative;background:var(--cream)}
.service-img img{width:100%;height:100%;object-fit:cover;transition:transform .8s ease}
.service-card:hover .service-img img{transform:scale(1.08)}
.service-num{position:absolute;top:20px;left:24px;font-family:"Fraunces",serif;font-style:italic;color:var(--paper);font-size:15px;letter-spacing:0.1em;text-shadow:0 1px 4px rgba(0,0,0,0.4);z-index:1}
.service-body{padding:32px}
.service-en{font-family:"Fraunces",serif;font-style:italic;color:var(--rust);font-size:13px;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:10px}
.service-name{font-family:"Gowun Batang",serif;font-size:26px;font-weight:400;margin-bottom:14px;color:var(--ink)}
.service-text{font-size:15px;line-height:1.7;color:var(--walnut);opacity:.85;margin-bottom:20px}
.service-arrow{font-family:"Fraunces",serif;font-style:italic;color:var(--wood);font-size:14px;display:inline-flex;align-items:center;gap:8px;transition:gap .3s ease}
.service-card:hover .service-arrow{gap:14px}

.about{padding:140px 48px;background:var(--cream);position:relative;z-index:2;border-top:1px solid var(--line);border-bottom:1px solid var(--line)}
.about-wrap{max-width:1240px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center}
.about-img{position:relative;border-radius:4px;overflow:hidden;aspect-ratio:4/5;background-size:cover;background-position:center;background-color:var(--wood);box-shadow:0 30px 80px rgba(43,29,17,0.2)}
.about-img::before{content:"";position:absolute;inset:0;background:linear-gradient(180deg,transparent 60%,rgba(43,29,17,0.5))}
.about-quote{position:absolute;bottom:32px;left:32px;right:32px;color:var(--paper);font-family:"Gowun Batang",serif;font-size:20px;line-height:1.6;z-index:1}
.about-content .section-label{margin-bottom:24px}
.about-content .section-title{text-align:left;margin-bottom:32px}
.about-text{font-size:16px;line-height:1.9;color:var(--walnut);margin-bottom:24px}
.timeline{margin-top:48px;border-top:1px solid var(--line);padding-top:32px}
.timeline-item{display:grid;grid-template-columns:90px 1fr;gap:24px;padding:18px 0;border-bottom:1px solid var(--line);align-items:baseline}
.timeline-year{font-family:"Fraunces",serif;font-size:20px;color:var(--rust);font-weight:500}
.timeline-text{font-size:15px;color:var(--walnut)}

.process{padding:140px 48px;position:relative;z-index:2}
.process-grid{max-width:1240px;margin:0 auto;display:grid;grid-template-columns:repeat(4,1fr);gap:0;position:relative}
.process-grid::before{content:"";position:absolute;top:42px;left:10%;right:10%;height:1px;background:repeating-linear-gradient(to right,var(--tan) 0,var(--tan) 6px,transparent 6px,transparent 12px);z-index:0}
.process-step{text-align:center;padding:0 16px;position:relative;z-index:1}
.process-num{width:84px;height:84px;margin:0 auto 28px;border-radius:50%;background:var(--paper);border:1px solid var(--wood);display:flex;align-items:center;justify-content:center;font-family:"Fraunces",serif;font-style:italic;font-size:28px;color:var(--wood);transition:all .4s ease}
.process-step:hover .process-num{background:var(--walnut);color:var(--paper);border-color:var(--walnut);transform:scale(1.1)}
.process-name{font-family:"Gowun Batang",serif;font-size:22px;font-weight:400;margin-bottom:12px;color:var(--ink)}
.process-desc{font-size:14px;line-height:1.7;color:var(--walnut);opacity:.8}

.gallery{padding:140px 48px;background:var(--walnut);color:var(--paper);position:relative;z-index:2}
.gallery .section-label{color:var(--sand)}
.gallery .section-title{color:var(--paper)}
.gallery .section-desc{color:var(--paper);opacity:.8}
.gallery-grid{max-width:1320px;margin:0 auto;display:grid;grid-template-columns:repeat(6,1fr);grid-auto-rows:200px;gap:16px;grid-auto-flow:dense}
.gallery-item{overflow:hidden;border-radius:4px;position:relative;cursor:pointer;background:var(--wood)}
.gallery-item img{width:100%;height:100%;object-fit:cover;transition:transform .8s ease, filter .4s ease;filter:brightness(0.92)}
.gallery-item:hover img{transform:scale(1.06);filter:brightness(1.05)}
.gallery-item::after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(43,29,17,0.7));opacity:0;transition:opacity .3s}
.gallery-item:hover::after{opacity:1}
.gallery-caption{position:absolute;bottom:20px;left:20px;font-family:"Gowun Batang",serif;font-size:15px;color:var(--paper);opacity:0;transform:translateY(8px);transition:all .4s ease;z-index:2}
.gallery-item:hover .gallery-caption{opacity:1;transform:translateY(0)}
.size-large{grid-column:span 3;grid-row:span 2}
.size-medium{grid-column:span 3;grid-row:span 1}
.size-medium-tall{grid-column:span 2;grid-row:span 2}
.size-small-wide{grid-column:span 2;grid-row:span 1}
.size-small{grid-column:span 1;grid-row:span 1}

.contact{padding:140px 48px;position:relative;z-index:2;background:var(--paper)}
.contact-wrap{max-width:1240px;margin:0 auto;display:grid;grid-template-columns:1fr 1.2fr;gap:80px}
.contact-info .section-label{margin-bottom:24px}
.contact-info .section-title{text-align:left;margin-bottom:32px}
.contact-blurb{font-size:16px;line-height:1.8;color:var(--walnut);opacity:.85;margin-bottom:48px}
.contact-detail{display:flex;gap:20px;align-items:flex-start;padding:24px 0;border-top:1px solid var(--line)}
.contact-detail:last-of-type{border-bottom:1px solid var(--line)}
.contact-icon{width:44px;height:44px;flex-shrink:0;border-radius:50%;background:var(--cream);display:flex;align-items:center;justify-content:center;font-size:18px}
.contact-label{font-family:"Fraunces",serif;font-style:italic;font-size:13px;color:var(--rust);letter-spacing:0.1em;text-transform:uppercase;margin-bottom:6px}
.contact-value{font-size:17px;color:var(--walnut);font-family:"Gowun Batang",serif}
.contact-value a{color:inherit;text-decoration:none}
.contact-value a:hover{color:var(--rust)}
.quick-contact{display:flex;gap:12px;margin-top:32px;flex-wrap:wrap}
.quick-contact a{flex:1;min-width:140px;padding:16px 20px;border-radius:999px;text-decoration:none;font-size:14px;text-align:center;display:inline-flex;align-items:center;justify-content:center;gap:8px;transition:all .3s ease}
.qc-call{background:var(--walnut);color:var(--paper)}
.qc-call:hover{background:var(--wood)}
.qc-kakao{background:#FEE500;color:#3A1D1D}
.qc-kakao:hover{background:#FFD600}

.contact-form{background:var(--bone);padding:48px;border-radius:8px;border:1px solid var(--line)}
.form-title{font-family:"Gowun Batang",serif;font-size:24px;margin-bottom:8px;color:var(--ink)}
.form-sub{font-size:14px;color:var(--walnut);opacity:.7;margin-bottom:32px}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:20px}
.form-group{margin-bottom:20px}
label{display:block;font-size:13px;color:var(--walnut);margin-bottom:8px;font-family:"Fraunces",serif;font-style:italic;letter-spacing:0.05em}
input,textarea,select{width:100%;padding:14px 16px;background:var(--paper);border:1px solid var(--line);border-radius:4px;font-family:inherit;font-size:15px;color:var(--walnut);transition:all .3s ease}
input:focus,textarea:focus,select:focus{outline:none;border-color:var(--wood);background:var(--bone);box-shadow:0 0 0 3px rgba(92,58,30,0.08)}
textarea{resize:vertical;min-height:120px;font-family:inherit}
.checkbox-row{display:flex;gap:16px;flex-wrap:wrap;margin-top:8px}
.checkbox-row label{display:inline-flex;align-items:center;gap:8px;cursor:pointer;margin:0;font-style:normal;font-family:inherit;font-size:14px;padding:8px 14px;border:1px solid var(--line);border-radius:999px;background:var(--paper);transition:all .25s ease}
.checkbox-row input{width:auto;margin:0;accent-color:var(--walnut)}
.checkbox-row label:has(input:checked){background:var(--walnut);color:var(--paper);border-color:var(--walnut)}
.form-submit{width:100%;padding:18px;background:var(--walnut);color:var(--paper);border:none;border-radius:999px;font-family:inherit;font-size:15px;cursor:pointer;letter-spacing:0.03em;transition:all .3s ease;margin-top:12px}
.form-submit:hover{background:var(--wood);transform:translateY(-2px)}
.form-note{text-align:center;font-size:12px;color:var(--walnut);opacity:.6;margin-top:14px}

footer{padding:64px 48px 32px;background:var(--walnut);color:var(--paper);position:relative;z-index:2}
.footer-wrap{max-width:1240px;margin:0 auto;display:grid;grid-template-columns:2fr 1fr 1fr;gap:48px;margin-bottom:48px}
.footer-brand{font-family:"Fraunces",serif;font-size:32px;font-weight:500;margin-bottom:16px;display:flex;align-items:center;gap:14px}
.footer-tag{font-size:14px;opacity:.7;line-height:1.7;max-width:380px}
.footer-col h4{font-family:"Fraunces",serif;font-style:italic;font-size:14px;color:var(--sand);margin-bottom:16px;letter-spacing:0.05em}
.footer-col p,.footer-col a{font-size:14px;opacity:.85;line-height:1.9;color:var(--paper);text-decoration:none;display:block}
.footer-col a:hover{opacity:1;color:var(--sand)}
.footer-bottom{padding-top:24px;border-top:1px solid rgba(246,239,226,0.15);display:flex;justify-content:space-between;align-items:center;font-size:12px;opacity:.6;flex-wrap:wrap;gap:12px}

.reveal{opacity:0;transform:translateY(40px);transition:opacity .8s ease, transform .8s ease}
.reveal.in{opacity:1;transform:translateY(0)}

@media (max-width:960px){
  nav{padding:16px 24px}
  .nav-links{display:none}
  .menu-btn{display:block}
  .hero{grid-template-columns:1fr;padding:120px 24px 60px;gap:48px}
  .hero-visual{height:420px}
  .hero-stamp{width:100px;height:100px;font-size:11px}
  .services,.about,.process,.gallery,.contact{padding:80px 24px}
  .service-grid{grid-template-columns:1fr;gap:24px}
  .about-wrap{grid-template-columns:1fr;gap:48px}
  .process-grid{grid-template-columns:repeat(2,1fr);gap:48px 16px}
  .process-grid::before{display:none}
  .gallery-grid{grid-template-columns:repeat(2,1fr);grid-auto-rows:180px}
  .size-large,.size-medium,.size-medium-tall,.size-small-wide,.size-small{grid-column:span 1;grid-row:span 1}
  .size-large{grid-column:span 2;grid-row:span 2}
  .contact-wrap{grid-template-columns:1fr;gap:48px}
  .contact-form{padding:32px 24px}
  .form-row{grid-template-columns:1fr}
  .footer-wrap{grid-template-columns:1fr;gap:32px}
}
</style>
</head>
<body>

<nav id="nav">
  <a href="#" class="logo">
    <svg class="logo-mark" viewBox="0 0 40 40" fill="none">
      <path d="M8 32 Q20 8 32 32" stroke="currentColor" stroke-width="1.5" fill="none"/>
      <path d="M14 32 Q20 18 26 32" stroke="currentColor" stroke-width="1.5" fill="none"/>
      <circle cx="20" cy="34" r="1.5" fill="currentColor"/>
    </svg>
    {{ settings.company.name_en }}
  </a>
  <ul class="nav-links">
    <li><a href="#services">제작 품목</a></li>
    <li><a href="#about">브랜드</a></li>
    <li><a href="#process">제작 과정</a></li>
    <li><a href="#gallery">시공 사례</a></li>
    <li><a href="#contact" class="nav-cta">문의하기</a></li>
  </ul>
  <button class="menu-btn" aria-label="menu">☰</button>
</nav>

<section class="hero">
  <div class="hero-bg"></div>
  <div class="hero-content">
    <div class="eyebrow">SINCE {{ settings.company.since }} · {{ settings.company.name_ko }}</div>
    <h1 class="hero-title">
      {{ settings.company.tagline_line1 }}<br>
      공간을 <em>{{ settings.company.tagline_line2 | replace("공간을 ", "") }}</em>
    </h1>
    <p class="hero-sub">{{ settings.company.hero_description }}</p>
    <div class="hero-actions">
      <a href="#contact" class="btn-primary">무료 견적 받기 →</a>
      <a href="#gallery" class="btn-secondary">시공 사례 보기</a>
    </div>
  </div>
  <div class="hero-visual">
    <div class="hero-img hero-img-1" style="background-image:url('{{ settings.hero_images.main }}')"></div>
    <div class="hero-img hero-img-2" style="background-image:url('{{ settings.hero_images.sub }}')"></div>
    <div class="hero-stamp">Handcrafted<br>in Korea<br><span style="font-size:18px">✦</span></div>
  </div>
</section>

<div class="marquee" aria-hidden="true">
  <div class="marquee-track">
    <span>맞춤 싱크대</span><span>붙박이장 제작</span><span>신발장 시공</span>
    <span>원목 가구</span><span>주방 리모델링</span><span>드레스룸</span>
    <span>맞춤 싱크대</span><span>붙박이장 제작</span><span>신발장 시공</span>
    <span>원목 가구</span><span>주방 리모델링</span><span>드레스룸</span>
  </div>
</div>

<section class="services" id="services">
  <div class="section-head reveal">
    <div class="section-label">Our Craft</div>
    <h2 class="section-title">집의 풍경이 되는<br>세 가지 가구</h2>
    <p class="section-desc">공간의 흐름을 읽고, 사용자의 습관을 살피며, 나무의 표정에 귀 기울입니다. 가람우드가 만드는 가구는 그렇게 시작됩니다.</p>
  </div>
  <div class="service-grid">
    {% for s in collections.services %}
    <div class="service-card reveal" style="transition-delay:{{ loop.index0 * 0.15 }}s">
      <div class="service-img">
        <span class="service-num">— {% if loop.index < 10 %}0{% endif %}{{ loop.index }}</span>
        <img src="{{ s.data.image }}" alt="{{ s.data.title }} 시공 사례">
      </div>
      <div class="service-body">
        <div class="service-en">{{ s.data.title_en }}</div>
        <h3 class="service-name">{{ s.data.title }}</h3>
        <p class="service-text">{{ s.data.description }}</p>
        <span class="service-arrow">자세히 보기 →</span>
      </div>
    </div>
    {% endfor %}
  </div>
</section>

<section class="about" id="about">
  <div class="about-wrap">
    <div class="about-img reveal" style="background-image:url('{{ settings.about.image }}')">
      <p class="about-quote">"{{ settings.about.quote }}"</p>
    </div>
    <div class="about-content reveal">
      <div class="section-label">About {{ settings.company.name_en }}</div>
      <h2 class="section-title">{{ settings.about.title }}</h2>
      <p class="about-text">{{ settings.about.paragraph1 }}</p>
      <p class="about-text">{{ settings.about.paragraph2 }}</p>
      <div class="timeline">
        {% for t in collections.timeline %}
        <div class="timeline-item">
          <div class="timeline-year">{{ t.data.year }}</div>
          <div class="timeline-text">{{ t.data.text }}</div>
        </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<section class="process" id="process">
  <div class="section-head reveal">
    <div class="section-label">How We Work</div>
    <h2 class="section-title">한 점의 가구가<br>완성되기까지</h2>
    <p class="section-desc">문의에서 설치까지, 가람우드가 함께하는 네 단계의 여정입니다.</p>
  </div>
  <div class="process-grid">
    <div class="process-step reveal"><div class="process-num">i</div><h3 class="process-name">상담 · 실측</h3><p class="process-desc">공간의 구조와 사용 습관을 듣고, 직접 방문해 정밀히 실측합니다.</p></div>
    <div class="process-step reveal" style="transition-delay:.1s"><div class="process-num">ii</div><h3 class="process-name">디자인 · 견적</h3><p class="process-desc">도면과 3D 시안을 함께 검토하며, 자재·예산에 맞춘 견적을 드립니다.</p></div>
    <div class="process-step reveal" style="transition-delay:.2s"><div class="process-num">iii</div><h3 class="process-name">제작</h3><p class="process-desc">자체 공방에서 한 점 한 점 손으로 만듭니다. 완성까지 보통 3~5주.</p></div>
    <div class="process-step reveal" style="transition-delay:.3s"><div class="process-num">iv</div><h3 class="process-name">설치 · 사후관리</h3><p class="process-desc">정밀 설치 후 1년간 무상 A/S, 이후에도 언제든 점검·수리 가능합니다.</p></div>
  </div>
</section>

<section class="gallery" id="gallery">
  <div class="section-head reveal">
    <div class="section-label">Portfolio</div>
    <h2 class="section-title">완성된 공간들</h2>
    <p class="section-desc">가람우드의 손을 거쳐 만들어진 집과 가구들.</p>
  </div>
  <div class="gallery-grid">
    {% for g in collections.gallery %}
    <div class="gallery-item size-{{ g.data.size or 'medium' }}">
      <img src="{{ g.data.image }}" alt="{{ g.data.title }}" loading="lazy">
      <div class="gallery-caption">{{ g.data.location }} · {{ g.data.title }}</div>
    </div>
    {% endfor %}
  </div>
</section>

<section class="contact" id="contact">
  <div class="contact-wrap">
    <div class="contact-info reveal">
      <div class="section-label">Get in Touch</div>
      <h2 class="section-title">시작은,<br>한 통의 연락부터</h2>
      <p class="contact-blurb">도면이 없어도, 사진 한 장이어도 괜찮습니다. 편하신 방법으로 연락 주시면, 빠르게 회신 드리겠습니다.</p>

      <div class="contact-detail">
        <div class="contact-icon">✆</div>
        <div><div class="contact-label">Phone</div><div class="contact-value"><a href="tel:{{ settings.contact.phone | replace('-','') }}">{{ settings.contact.phone_display }}</a></div></div>
      </div>
      <div class="contact-detail">
        <div class="contact-icon">✉</div>
        <div><div class="contact-label">Email</div><div class="contact-value"><a href="mailto:{{ settings.contact.email }}">{{ settings.contact.email }}</a></div></div>
      </div>
      <div class="contact-detail">
        <div class="contact-icon">⌂</div>
        <div><div class="contact-label">Studio</div><div class="contact-value">{{ settings.contact.address }}<br><span style="font-size:14px;opacity:.7;font-family:'Gowun Dodum'">{{ settings.contact.hours }}</span></div></div>
      </div>
      <div class="contact-detail">
        <div class="contact-icon">◯</div>
        <div><div class="contact-label">Instagram</div><div class="contact-value"><a href="{{ settings.contact.instagram_url }}" target="_blank">@{{ settings.contact.instagram_handle }}</a></div></div>
      </div>

      <div class="quick-contact">
        <a href="tel:{{ settings.contact.phone | replace('-','') }}" class="qc-call">📞 전화 상담</a>
        <a href="{{ settings.contact.kakao_url }}" class="qc-kakao">💬 카카오톡 상담</a>
      </div>
    </div>

    <form class="contact-form reveal" id="inquiryForm" data-email="{{ settings.contact.email }}">
      <h3 class="form-title">견적 · 상담 문의</h3>
      <p class="form-sub">아래 내용을 남겨주시면 24시간 내 회신 드리겠습니다.</p>
      <div class="form-row">
        <div class="form-group" style="margin-bottom:0"><label for="name">성함</label><input type="text" id="name" name="name" required placeholder="홍길동"></div>
        <div class="form-group" style="margin-bottom:0"><label for="phone">연락처</label><input type="tel" id="phone" name="phone" required placeholder="010-0000-0000"></div>
      </div>
      <div class="form-group"><label for="email">이메일 (선택)</label><input type="email" id="email" name="email" placeholder="example@email.com"></div>
      <div class="form-group">
        <label>문의 품목 (복수 선택 가능)</label>
        <div class="checkbox-row">
          <label><input type="checkbox" name="item" value="싱크대"> 싱크대</label>
          <label><input type="checkbox" name="item" value="붙박이장"> 붙박이장</label>
          <label><input type="checkbox" name="item" value="신발장"> 신발장</label>
          <label><input type="checkbox" name="item" value="기타"> 기타</label>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group" style="margin-bottom:0"><label for="area">시공 지역</label><input type="text" id="area" name="area" placeholder="예: 성남시 분당구"></div>
        <div class="form-group" style="margin-bottom:0"><label for="budget">예산 (선택)</label><select id="budget" name="budget"><option value="">선택해주세요</option><option value="~300만원">300만원 이하</option><option value="300~500">300 – 500만원</option><option value="500~1000">500 – 1,000만원</option><option value="1000+">1,000만원 이상</option><option value="미정">미정 · 상담 후 결정</option></select></div>
      </div>
      <div class="form-group"><label for="message">상세 문의 내용</label><textarea id="message" name="message" placeholder="공간 크기, 원하시는 스타일, 일정 등 자유롭게 적어주세요."></textarea></div>
      <button type="submit" class="form-submit">문의 보내기 →</button>
      <p class="form-note">전송 시 {{ settings.contact.email }} 으로 메일이 발송됩니다.</p>
    </form>
  </div>
</section>

<footer>
  <div class="footer-wrap">
    <div>
      <div class="footer-brand">
        <svg width="36" height="36" viewBox="0 0 40 40" fill="none">
          <path d="M8 32 Q20 8 32 32" stroke="currentColor" stroke-width="1.5"/>
          <path d="M14 32 Q20 18 26 32" stroke="currentColor" stroke-width="1.5"/>
          <circle cx="20" cy="34" r="1.5" fill="currentColor"/>
        </svg>
        {{ settings.company.name_en }}
      </div>
      <p class="footer-tag">나무의 결을 따라 공간을 짓는 사람들.<br>싱크대 · 붙박이장 · 신발장 맞춤 제작.</p>
    </div>
    <div class="footer-col">
      <h4>Contact</h4>
      <a href="tel:{{ settings.contact.phone | replace('-','') }}">{{ settings.contact.phone_display }}</a>
      <a href="mailto:{{ settings.contact.email }}">{{ settings.contact.email }}</a>
      <p>{{ settings.contact.address }}</p>
    </div>
    <div class="footer-col">
      <h4>Follow</h4>
      <a href="{{ settings.contact.instagram_url }}" target="_blank">Instagram</a>
    </div>
  </div>
  <div class="footer-bottom">
    <span>© 2026 {{ settings.company.name_en }}. All rights reserved.</span>
    <span>garamwood.com</span>
  </div>
</footer>

<script>
const nav = document.getElementById('nav');
window.addEventListener('scroll', () => nav.classList.toggle('scrolled', window.scrollY > 30));

const io = new IntersectionObserver((entries) => {
  entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
}, { threshold: 0.12 });
document.querySelectorAll('.reveal').forEach(el => io.observe(el));

document.getElementById('inquiryForm').addEventListener('submit', (e) => {
  e.preventDefault();
  const f = e.target;
  const items = [...f.querySelectorAll('input[name="item"]:checked')].map(i => i.value).join(', ') || '미선택';
  const body = `성함: ${f.name.value}\n연락처: ${f.phone.value}\n이메일: ${f.email.value || '-'}\n문의 품목: ${items}\n시공 지역: ${f.area.value || '-'}\n예산: ${f.budget.value || '-'}\n\n[상세 내용]\n${f.message.value || '-'}`;
  const subject = encodeURIComponent(`[가람우드 문의] ${f.name.value} 님`);
  window.location.href = `mailto:${f.dataset.email}?subject=${subject}&body=${encodeURIComponent(body)}`;
});
</script>
</body>
</html>
